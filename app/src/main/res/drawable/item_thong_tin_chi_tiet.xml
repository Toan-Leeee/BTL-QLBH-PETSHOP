<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="110dp"
            android:layout_height="wrap_content"
            android:text="SKU"
            android:textColor="#8C969F"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtSku"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="#1000078"
            android:textColor="#5B6670"
            android:textSize="14sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E3E7EB" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="110dp"
            android:layout_height="wrap_content"
            android:text="Giống"
            android:textColor="#8C969F"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtGiong"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cái"
            android:textColor="#5B6670"
            android:textSize="14sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E3E7EB" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="110dp"
            android:layout_height="wrap_content"
            android:text="Tuổi"
            android:textColor="#8C969F"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtTuoi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2 tháng"
            android:textColor="#5B6670"
            android:textSize="14sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E3E7EB" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="110dp"
            android:layout_height="wrap_content"
            android:text="Kích thước"
            android:textColor="#8C969F"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtKichThuoc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nhỏ"
            android:textColor="#5B6670"
            android:textSize="14sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E3E7EB" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="110dp"
            android:layout_height="wrap_content"
            android:text="Màu sắc"
            android:textColor="#8C969F"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtMauSac"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nâu đỏ"
            android:textColor="#5B6670"
            android:textSize="14sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E3E7EB" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="110dp"
            android:layout_height="wrap_content"
            android:text="Mô tả ngắn"
            android:textColor="#8C969F"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtMoTa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:lineSpacingExtra="2dp"
            android:text="Mô tả ngắn"
            android:textColor="#5B6670"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>
