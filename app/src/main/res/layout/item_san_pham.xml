<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:background="@drawable/bg_product_card"
    android:elevation="1dp"
    android:orientation="vertical"
    android:padding="8dp">

    <ImageView
        android:id="@+id/imgSanPham"
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:adjustViewBounds="true"
        android:contentDescription="sanpham"
        android:scaleType="centerCrop"
        android:src="@null" />

    <TextView
        android:id="@+id/txtTenSanPham"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text=""
        android:textColor="#222222"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtGiong"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text=""
        android:textColor="#777777"
        android:textSize="10sp" />

    <TextView
        android:id="@+id/txtTuoi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#777777"
        android:textSize="10sp" />

    <TextView
        android:id="@+id/txtGia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text=""
        android:textColor="#0B3B68"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>