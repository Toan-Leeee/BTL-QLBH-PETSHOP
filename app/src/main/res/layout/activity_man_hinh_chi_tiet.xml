<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monito"
                android:textColor="#0B3B68"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pets for Best"
                android:textColor="#0B3B68"
                android:textSize="8sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Main image -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="320dp">

            <ImageView
                android:id="@+id/imgMain"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:contentDescription="áº¢nh thÃº cÆ°ng"
                android:scaleType="centerCrop"
                android:src="@null" />

            <ImageView
                android:id="@+id/btnPrev"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_circle_soft"
                android:contentDescription="prev"
                android:padding="12dp"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#FFFFFF" />

            <ImageView
                android:id="@+id/btnNext"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_circle_soft"
                android:contentDescription="next"
                android:padding="12dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#FFFFFF" />

            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="start|top"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_circle_soft"
                android:contentDescription="menu"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="#FFFFFF" />
        </FrameLayout>

        <!-- Extra banner image strip -->

        <!-- Thumbnails -->
        <ImageView
            android:id="@+id/imgBannerSecondary"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:adjustViewBounds="true"
            android:contentDescription="áº¢nh phá»¥"
            android:scaleType="centerCrop"
            android:src="@null" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <ImageView
                    android:id="@+id/thumb1"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_thumb_frame"
                    android:contentDescription="thumb1"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    android:src="@null" />

                <ImageView
                    android:id="@+id/thumb2"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_thumb_frame"
                    android:contentDescription="thumb2"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    android:src="@null" />

                <ImageView
                    android:id="@+id/thumb3"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_thumb_frame"
                    android:contentDescription="thumb3"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    android:src="@null" />

                <ImageView
                    android:id="@+id/thumb4"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_thumb_frame"
                    android:contentDescription="thumb4"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    android:src="@null" />

                <ImageView
                    android:id="@+id/thumb5"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_thumb_frame"
                    android:contentDescription="thumb5"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    android:src="@null" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Main content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="18dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/txtTen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#102C43"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtGia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text=""
                android:textColor="#0B3B68"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnMuaNgay"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_register_button"
                    android:text="Mua Ngay"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="12dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnThemVaoGio"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_outline"
                    android:text="Them vao gio"
                    android:textAllCaps="false"
                    android:textColor="#0B3B68"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Detail table -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="vertical"
                android:background="@android:color/transparent">

                <include layout="@layout/item_thong_tin_chi_tiet" />

            </LinearLayout>

            <!-- Share -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chia sẻ"
                    android:textColor="#0B3B68"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="14dp"
                    android:src="@android:drawable/ic_menu_share"
                    app:tint="#9AA4AC" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="16dp"
                    android:src="@android:drawable/ic_menu_share"
                    app:tint="#9AA4AC" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="16dp"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="#9AA4AC" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="16dp"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="#9AA4AC" />
            </LinearLayout>
        </LinearLayout>
        <!-- Related products -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="28dp"
            android:text="Có gì mới"
            android:textColor="#6B7280"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="2dp"
            android:text="Xem Thêm thú cưng"
            android:textColor="#0B3B68"
            android:textSize="18sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvLienQuan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="12dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
