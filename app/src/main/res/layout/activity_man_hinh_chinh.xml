<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7EEDC"
    android:fillViewport="true"
    tools:context=".ui.ManHinhChinhActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:background="@drawable/bg_header_top">

            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentStart="true"
                android:layout_marginStart="16dp"
                android:layout_marginTop="28dp"
                android:contentDescription="menu"
                android:src="@android:drawable/ic_menu_sort_by_size" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtLogo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monito"
                    android:textColor="#0B3B68"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pets for Best"
                    android:textColor="#0B3B68"
                    android:textSize="8sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:id="@+id/imgAvatar"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="26dp"
                android:layout_marginEnd="16dp"
                android:contentDescription="avatar"
                android:src="@drawable/avatar" />
        </RelativeLayout>

        <!-- HERO TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="8dp"
            android:text="Them Mot Ban"
            android:textColor="#002B5B"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="2dp"
            android:text="Them Ngan Niem Vui!"
            android:textColor="#002B5B"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="18dp"
            android:lineSpacingExtra="2dp"
            android:text="Co mot con thu cung dong nghia voi viec ban co them niem vui moi. Chung toi co hon 200 con thu cung khoe manh de dap ung nhu cau cua ban!"
            android:textColor="#2D2D2D"
            android:textSize="11sp" />

        <!-- BUTTONS -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnGioiThieu"
                android:layout_width="123dp"
                android:layout_height="50dp"
                android:background="@drawable/bg_btn_outline"
                android:text="Gioi Thieu"
                android:textAllCaps="false"
                android:textColor="#0B3B68"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnKhamPha"
                android:layout_width="151dp"
                android:layout_height="50dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_register_button"
                android:text="Kham Pha Ngay"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- HERO IMAGE BLOCK -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="16dp">

            <View
                android:layout_width="150dp"
                android:layout_height="160dp"
                android:layout_gravity="start|bottom"
                android:background="@drawable/bg_blue_blob" />

            <View
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:layout_gravity="center_horizontal|top"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_be_circle" />

            <ImageView
                android:id="@+id/imgHero"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:contentDescription="hero"
                android:scaleType="fitCenter"
                android:src="@drawable/herdoghome" />
        </FrameLayout>

        <!-- PRODUCT TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:text="Co gi moi?"
            android:textColor="#555555"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="2dp"
            android:text="Mot So Vat Nuoi Cua Chung Toi"
            android:textColor="#0B3B68"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- PRODUCTS -->
        <GridLayout
            tools:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="12dp"
            android:columnCount="2"
            android:useDefaultMargins="true">

            <LinearLayout
                android:id="@+id/cardPet1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_card_white"
                android:clickable="true"
                android:elevation="1dp"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/imgPet1"
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:contentDescription="pet1"
                    android:scaleType="centerCrop"
                    android:src="@null" />

                <TextView
                    android:id="@+id/txtTenPet1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text=""
                    android:textColor="#222222"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtGiongPet1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text=""
                    android:textColor="#777777"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/txtTuoiPet1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#777777"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/txtGiaPet1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text=""
                    android:textColor="#0B3B68"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardPet2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_card_white"
                android:clickable="true"
                android:elevation="1dp"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/imgPet2"
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:contentDescription="pet2"
                    android:scaleType="centerCrop"
                    android:src="@null" />

                <TextView
                    android:id="@+id/txtTenPet2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text=""
                    android:textColor="#222222"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtGiongPet2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text=""
                    android:textColor="#777777"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/txtTuoiPet2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#777777"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/txtGiaPet2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text=""
                    android:textColor="#0B3B68"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardPet3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_card_white"
                android:clickable="true"
                android:elevation="1dp"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/imgPet3"
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:contentDescription="pet3"
                    android:scaleType="centerCrop"
                    android:src="@null" />

                <TextView
                    android:id="@+id/txtTenPet3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text=""
                    android:textColor="#222222"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtGiongPet3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text=""
                    android:textColor="#777777"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/txtTuoiPet3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#777777"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/txtGiaPet3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text=""
                    android:textColor="#0B3B68"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardPet4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_card_white"
                android:clickable="true"
                android:elevation="1dp"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/imgPet4"
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:contentDescription="pet4"
                    android:scaleType="centerCrop"
                    android:src="@null" />

                <TextView
                    android:id="@+id/txtTenPet4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text=""
                    android:textColor="#222222"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtGiongPet4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text=""
                    android:textColor="#777777"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/txtTuoiPet4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#777777"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/txtGiaPet4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text=""
                    android:textColor="#0B3B68"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </GridLayout>

        <!-- ARTICLE TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="18dp"
            android:text="Ban co the can"
            android:textColor="#555555"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="2dp"
            android:text="Kien thuc thu cung Huu Ich"
            android:textColor="#0B3B68"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:contentDescription="article1"
                android:scaleType="centerCrop"
                android:src="@drawable/cholongtrang" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Kien thuc thu cung"
                android:textColor="#0B3B68"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Nhung dieu can biet khi cham soc cho con moi ve nha"
                android:textColor="#222222"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Chuan bi cho ngu, thuc an, ve sinh va thoi gian lam quen de be thich nghi tot hon."
                android:textColor="#666666"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:contentDescription="article2"
                android:scaleType="centerCrop"
                android:src="@drawable/cholongnau" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Kien thuc thu cung"
                android:textColor="#0B3B68"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Che do dinh duong phu hop cho tung giong cho"
                android:textColor="#222222"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Chon khau phan theo do tuoi, can nang va muc van dong de thu cung phat trien khoe manh."
                android:textColor="#666666"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
